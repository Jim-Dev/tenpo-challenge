# Docker Compose Environment Variables Example
# Copy this file to .env and fill in the values

# PostgreSQL Configuration
POSTGRES_DB=tenpo_db_challenge
POSTGRES_USER=tenpo_db_user
POSTGRES_PASSWORD=tenpo_db_pass

# Spring Boot Configuration (for app service)
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/tenpo_db_challenge
SPRING_DATASOURCE_USERNAME=tenpo_db_user
SPRING_DATASOURCE_PASSWORD=tenpo_db_pass
